# Shopify Store Configuration
SHOPIFY_STORE_DOMAIN="[your-shopify-store-subdomain].myshopify.com"

# Storefront API Tokens (Headless Sales Channel / Custom App)
# For server-side/server-to-server queries - REQUIRED
SHOPIFY_STOREFRONT_PRIVATE_ACCESS_TOKEN=""

# For client-side/browser queries (optional - if doing client-side fetching)
SHOPIFY_STOREFRONT_PUBLIC_ACCESS_TOKEN=""

# Revalidation Secret (for webhook-based cache revalidation)
# Get this from your Headless channel API credentials or webhook settings
SHOPIFY_REVALIDATION_SECRET=""